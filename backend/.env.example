# Backend environment example.
# Copy to `backend/.env` locally and fill with real values from a secrets manager.

# App / runtime
APP_NAME=J.A.R.V.I.S.
APP_ENV=development
DEBUG=true
APP_VERSION=1.0.0

# Security
SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALLOW_INSECURE_DEV_AUTH=false
DEV_AUTH_SECRET=

# CORS
# Comma-separated origins. Avoid `*` outside local development.
CORS_ALLOWED_ORIGINS=["http://localhost:8081","http://localhost:19006"]

# Database
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_dev@localhost:5432/jarvis_db
REDIS_URL=redis://localhost:6379/0

# Providers
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws

# Observability
SENTRY_DSN=
